#:kivy 2.2

<SetupScreen>:
    name: 'setup'
    BoxLayout:
        orientation: 'vertical'
        MDTopAppBar:
            title: '日文背词'
            md_bg_color: app.theme_cls.primary_color
            specific_text_color: 1,1,1,1
        BoxLayout:
            orientation: 'vertical'
            padding: [dp(12), dp(8)]
            spacing: dp(8)
            ScrollView:
                MDBoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(8)
                    padding: [0, 0, 0, dp(16)]

                    MDLabel:
                        id: streak_info
                        text: ''
                        font_size: sp(12)
                        halign: 'center'
                        theme_text_color: 'Primary'
                        size_hint_y: None
                        height: dp(20)

                    MDCard:
                        id: progress_card
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: dp(60)
                        padding: [dp(12), dp(8)]
                        opacity: 0
                        MDLabel:
                            id: progress_text
                            text: ''
                            font_size: sp(14)
                            size_hint_x: .6
                        MDFlatButton:
                            text: '继续'
                            id: btn_resume
                            size_hint_x: .2
                        MDFlatButton:
                            text: '重新开始'
                            id: btn_resume_clear
                            size_hint_x: .2

                    MDCard:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        padding: [dp(8), dp(8)]

                        MDLabel:
                            text: '选择背诵级别：'
                            font_size: sp(14)
                            size_hint_y: None
                            height: dp(30)

                        MDBoxLayout:
                            id: level_box
                            orientation: 'vertical'
                            size_hint_y: None
                            height: self.minimum_height

                        MDDivider:
                            height: dp(1)
                            size_hint_y: None

                        BoxLayout:
                            orientation: 'horizontal'
                            size_hint_y: None
                            height: dp(48)
                            padding: [dp(8), dp(8)]
                            spacing: dp(8)
                            MDLabel:
                                text: '每轮题数：'
                                font_size: sp(14)
                                size_hint_x: .5
                                valign: 'middle'
                            TextInput:
                                id: quiz_count
                                text: '10'
                                input_filter: 'int'
                                multiline: False
                                size_hint_x: .15
                                halign: 'center'
                                font_size: sp(16)

                    MDRaisedButton:
                        id: btn_start
                        text: '开始答题'
                        size_hint: (.6, None)
                        height: dp(52)
                        pos_hint: {'center_x': .5}
                        disabled: True
                        on_release: root.start_quiz()
                        md_bg_color: app.theme_cls.primary_color

                    MDLabel:
                        id: level_info
                        text: '请至少选择一个级别'
                        font_size: sp(13)
                        halign: 'center'
                        theme_text_color: 'Secondary'
                        size_hint_y: None
                        height: dp(40)

<QuizScreen>:
    name: 'quiz'
    BoxLayout:
        orientation: 'vertical'
        MDBoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(36)
            padding: [dp(12), dp(4)]
            spacing: dp(4)
            MDLabel:
                id: q_counter
                text: '第 1 / 10 题'
                font_size: sp(13)
                size_hint_x: .3
            MDLabel:
                id: q_type
                text: '[日译中]'
                font_size: sp(12)
                bold: True
                theme_text_color: 'Primary'
                size_hint_x: .15
            MDLabel:
                id: q_remaining
                text: '剩余 0 词'
                font_size: sp(12)
                theme_text_color: 'Secondary'
                size_hint_x: .25
            MDLabel:
                id: q_score
                text: '✓ 0  ✗ 0'
                font_size: sp(13)
                halign: 'right'
                size_hint_x: .3

        MDProgressBar:
            id: progress_bar
            size_hint_y: None
            height: dp(4)
            value: 0

        ScrollView:
            MDBoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(8), dp(8)]
                spacing: dp(8)

                MDCard:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    padding: [dp(16), dp(12)]
                    spacing: dp(8)

                    BoxLayout:
                        id: word_area
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(4)

                        MDLabel:
                            id: q_furigana
                            text: ''
                            font_size: sp(16)
                            halign: 'center'
                            theme_text_color: 'Primary'
                            size_hint_y: None
                            height: dp(24)

                        BoxLayout:
                            orientation: 'horizontal'
                            size_hint_y: None
                            height: dp(60)
                            spacing: dp(8)
                            Widget:
                                size_hint_x: .1
                            MDLabel:
                                id: q_kanji
                                text: ''
                                font_size: sp(36)
                                bold: True
                                halign: 'center'
                                valign: 'middle'
                                size_hint_x: .8
                            MDIconButton:
                                id: btn_pronounce
                                icon: 'volume-high'
                                theme_icon_color: 'Primary'
                                size_hint_x: .1
                                on_release: app.play_sound()

                        MDLabel:
                            id: pos_label
                            text: ''
                            font_size: sp(12)
                            halign: 'center'
                            theme_text_color: 'Secondary'
                            size_hint_y: None
                            height: dp(20)

                    BoxLayout:
                        id: def_area
                        orientation: 'vertical'
                        size_hint_y: None
                        height: dp(80)

                        MDLabel:
                            id: q_def
                            text: ''
                            font_size: sp(22)
                            halign: 'center'
                            size_hint_y: None
                            height: dp(60)

                    BoxLayout:
                        id: input_area
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(4)

                        MDLabel:
                            id: prompt1
                            text: '请输入中文释义：'
                            font_size: sp(13)
                            size_hint_y: None
                            height: dp(20)

                        MDTextField:
                            id: ans_input1
                            hint_text: '输入答案'
                            font_size: sp(18)
                            multiline: False
                            mode: 'fill'
                            size_hint_y: None
                            height: dp(52)
                            on_text_validate: root.submit()

                        BoxLayout:
                            id: input2_group
                            orientation: 'vertical'
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(2)

                            MDLabel:
                                id: prompt2
                                text: '请输入读音（振假名）：'
                                font_size: sp(13)
                                size_hint_y: None
                                height: dp(20)

                            MDTextField:
                                id: ans_input2
                                hint_text: '读音'
                                font_size: sp(18)
                                multiline: False
                                mode: 'fill'
                                size_hint_y: None
                                height: dp(52)
                                on_text_validate: root.submit()

                    MDRaisedButton:
                        id: btn_submit
                        text: '提交'
                        size_hint: (.5, None)
                        height: dp(48)
                        pos_hint: {'center_x': .5}
                        on_release: root.submit()

                    BoxLayout:
                        id: feedback_area
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(4)

                        MDLabel:
                            id: fb_icon
                            text: ''
                            font_size: sp(28)
                            halign: 'center'
                            size_hint_y: None
                            height: dp(36)

                        MDLabel:
                            id: fb_answer
                            text: ''
                            font_size: sp(16)
                            halign: 'center'
                            size_hint_y: None
                            height: dp(28)

                        MDLabel:
                            id: fb_srs
                            text: ''
                            font_size: sp(11)
                            halign: 'center'
                            theme_text_color: 'Secondary'
                            size_hint_y: None
                            height: dp(20)

                        MDLabel:
                            id: fb_plus
                            text: ''
                            font_size: sp(13)
                            halign: 'center'
                            theme_text_color: 'Hint'
                            size_hint_y: None
                            height: dp(20)

                        MDBoxLayout:
                            id: sent_box
                            orientation: 'vertical'
                            size_hint_y: None
                            height: self.minimum_height

                    MDRaisedButton:
                        id: btn_next
                        text: '下一题 →'
                        size_hint: (.5, None)
                        height: dp(48)
                        pos_hint: {'center_x': .5}
                        on_release: root.next()

<ResultScreen>:
    name: 'result'
    BoxLayout:
        orientation: 'vertical'
        MDTopAppBar:
            title: '练习结果'
            md_bg_color: app.theme_cls.primary_color
            specific_text_color: 1,1,1,1

        ScrollView:
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(16), dp(16)]
                spacing: dp(12)

                MDLabel:
                    id: result_pct
                    text: '0%'
                    font_size: sp(56)
                    bold: True
                    halign: 'center'
                    theme_text_color: 'Primary'
                    size_hint_y: None
                    height: dp(80)

                MDLabel:
                    id: result_detail
                    text: ''
                    font_size: sp(14)
                    halign: 'center'
                    theme_text_color: 'Secondary'
                    size_hint_y: None
                    height: dp(50)

                MDCard:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    padding: [dp(4), dp(4)]

                    ScrollView:
                        size_hint_y: None
                        height: dp(300)

                        MDBoxLayout:
                            id: result_list
                            orientation: 'vertical'
                            size_hint_y: None
                            height: self.minimum_height

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(52)
                    spacing: dp(12)
                    size_hint_x: .8
                    pos_hint: {'center_x': .5}

                    MDRaisedButton:
                        text: '再来一组'
                        on_release: app.next_round()
                    MDFlatButton:
                        text: '返回主页'
                        on_release: app.go_home()

<WrongBankScreen>:
    name: 'wrong'
    BoxLayout:
        orientation: 'vertical'
        MDTopAppBar:
            title: '错题本'
            md_bg_color: app.theme_cls.primary_color
            specific_text_color: 1,1,1,1

        ScrollView:
            MDBoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(12), dp(8)]
                spacing: dp(8)

                MDBoxLayout:
                    id: wb_container
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(4)

                BoxLayout:
                    id: wb_actions
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(52)
                    spacing: dp(8)
                    size_hint_x: .9
                    pos_hint: {'center_x': .5}

                    MDRaisedButton:
                        text: '复习选中级别'
                        on_release: root.review_selected()
                    MDFlatButton:
                        text: '清空错题本'
                        theme_text_color: 'Error'
                        on_release: root.clear_confirm()
